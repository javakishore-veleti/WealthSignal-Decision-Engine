{
  "name": "wealthsignal-decision-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Operational root — orchestrates the WealthSignal Decision Engine monorepo (FastAPI middleware + Angular portals + Airflow + DevOps). This package.json is operational only; no runtime JS lives at the repo root.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/javakishore-veleti/WealthSignal-Decision-Engine.git"
  },
  "author": "Kishore Veleti",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "portals/admin_portal",
    "portals/customer_portal"
  ],
  "scripts": {
    "//": "─── SETUP: one-time local dev environment ───────────────────────",
    "setup:local:all": "npm-run-all -s setup:local:conda setup:local:python setup:local:portals setup:local:precommit",
    "setup:local:conda": "conda env create -f environment.yml || conda env update -f environment.yml",
    "setup:local:python": "pip install -e \".[dev]\"",
    "setup:local:portals": "npm install",
    "setup:local:precommit": "pre-commit install",
    "setup:local:airflow": "bash DevOps/Local/airflow/init.sh",

    "//1": "─── RUN · DOCKER: local infrastructure containers ─────────────",
    "run:local:docker:all": "bash DevOps/Local/docker-all-up.sh",
    "run:local:docker:status": "bash DevOps/Local/docker-all-status.sh",
    "run:local:docker:shutdown": "bash DevOps/Local/docker-all-down.sh",
    "run:local:docker:airflow": "docker compose -f DevOps/Local/airflow/docker-compose.yml up -d",
    "run:local:docker:postgres": "docker compose -f DevOps/Local/postgres/docker-compose.yml up -d",
    "run:local:docker:kafka": "docker compose -f DevOps/Local/kafka/docker-compose.yml up -d",
    "run:local:docker:observability": "docker compose -f DevOps/Local/Observability/docker-compose.yml up -d",

    "//2": "─── RUN · MIDDLEWARE: FastAPI services ───────────────────────",
    "run:local:middleware:all": "bash DevOps/Local/middleware/up.sh",
    "run:local:middleware:status": "bash DevOps/Local/middleware/status.sh",
    "run:local:middleware:shutdown": "bash DevOps/Local/middleware/shutdown.sh",
    "run:local:middleware:admin": "uvicorn middleware.admin_api.app.main:app --reload --port 8001",
    "run:local:middleware:customer": "uvicorn middleware.customer_api.app.main:app --reload --port 8002",
    "run:local:middleware:data-management": "uvicorn middleware.data_management_api.app.main:app --reload --port 8003",
    "run:local:middleware:product-catalog": "uvicorn middleware.product_catalog_api.app.main:app --reload --port 8004",

    "seed:products": "python -m middleware.product_catalog_api.app.seed.generate_products --count 10000 --out data/product_catalog/products_seed.json",

    "//3": "─── RUN · PORTALS: Angular applications ──────────────────────",
    "run:local:portals:all": "bash DevOps/Local/portals/up.sh",
    "run:local:portals:status": "bash DevOps/Local/portals/status.sh",
    "run:local:portals:shutdown": "bash DevOps/Local/portals/shutdown.sh",
    "run:local:portals:admin": "npm run start --workspace=portals/admin_portal",
    "run:local:portals:customer": "npm run start --workspace=portals/customer_portal",

    "//4": "─── RUN · STACK: everything at once ──────────────────────────",
    "run:local:all": "npm-run-all -s run:local:docker:all run:local:middleware:all run:local:portals:all",
    "run:local:status": "npm-run-all -s run:local:docker:status run:local:middleware:status run:local:portals:status",
    "run:local:shutdown": "npm-run-all -s run:local:portals:shutdown run:local:middleware:shutdown run:local:docker:shutdown",

    "//5": "─── BUILD · portals (production artefacts) ───────────────────",
    "build:portals": "npm run build --workspaces --if-present",

    "//6": "─── LINT & FORMAT ────────────────────────────────────────────",
    "lint:python": "ruff check . && black --check .",
    "lint:portals": "npm run lint --workspaces --if-present",
    "lint:all": "npm-run-all -s lint:python lint:portals",
    "format:python": "ruff check --fix . && black .",

    "//7": "─── TEST ─────────────────────────────────────────────────────",
    "test:python": "pytest tests/ -v --cov=engine --cov=middleware",
    "test:portals": "npm run test --workspaces --if-present",
    "test:airflow": "pytest tests/airflow/ -v",
    "test:all": "npm-run-all -s test:python test:airflow test:portals"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "keywords": [
    "wealth-management",
    "fintech",
    "pytorch",
    "mlflow",
    "fastapi",
    "angular",
    "airflow",
    "customer-r1",
    "decision-engine",
    "monorepo"
  ]
}
