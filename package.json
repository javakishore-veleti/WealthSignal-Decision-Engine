{
  "name": "wealthsignal-decision-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Operational root — orchestrates the WealthSignal Decision Engine monorepo (FastAPI middleware + Angular portals + Airflow + DevOps). This package.json is operational only; no runtime JS lives at the repo root.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/javakishore-veleti/WealthSignal-Decision-Engine.git"
  },
  "author": "Kishore Veleti",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "portals/admin_portal",
    "portals/customer_portal"
  ],
  "scripts": {
    "docker:up": "bash DevOps/Local/docker-all-up.sh",
    "docker:down": "bash DevOps/Local/docker-all-down.sh",
    "docker:status": "bash DevOps/Local/docker-all-status.sh",

    "infra:airflow:up": "docker compose -f DevOps/Local/airflow/docker-compose.yml up -d",
    "infra:airflow:down": "docker compose -f DevOps/Local/airflow/docker-compose.yml down",
    "infra:postgres:up": "docker compose -f DevOps/Local/postgres/docker-compose.yml up -d",
    "infra:postgres:down": "docker compose -f DevOps/Local/postgres/docker-compose.yml down",
    "infra:kafka:up": "docker compose -f DevOps/Local/kafka/docker-compose.yml up -d",
    "infra:kafka:down": "docker compose -f DevOps/Local/kafka/docker-compose.yml down",
    "infra:observability:up": "docker compose -f DevOps/Local/Observability/docker-compose.yml up -d",
    "infra:observability:down": "docker compose -f DevOps/Local/Observability/docker-compose.yml down",

    "portals:install": "npm install --workspaces --if-present",
    "portals:build": "npm run build --workspaces --if-present",
    "portals:lint": "npm run lint --workspaces --if-present",
    "portals:test": "npm run test --workspaces --if-present",

    "dev:admin": "npm run start --workspace=portals/admin_portal",
    "dev:customer": "npm run start --workspace=portals/customer_portal",

    "api:admin": "uvicorn middleware.admin_api.app.main:app --reload --port 8001",
    "api:customer": "uvicorn middleware.customer_api.app.main:app --reload --port 8002",
    "api:data-management": "uvicorn middleware.data_management_api.app.main:app --reload --port 8003",

    "lint:python": "ruff check . && black --check .",
    "format:python": "ruff check --fix . && black .",
    "test:python": "pytest tests/ -v --cov=engine --cov=middleware",
    "test:airflow": "pytest tests/airflow/ -v",

    "lint": "npm run lint:python && npm run portals:lint",
    "test": "npm run test:python && npm run portals:test",
    "build": "npm run portals:build"
  },
  "keywords": [
    "wealth-management",
    "fintech",
    "pytorch",
    "mlflow",
    "fastapi",
    "angular",
    "airflow",
    "customer-r1",
    "decision-engine",
    "monorepo"
  ]
}
